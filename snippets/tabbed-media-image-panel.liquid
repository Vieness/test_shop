{%- doc -%}
  Renders an image panel for the tabbed media section.

  @param {object} block - The section block
  @param {string} section_id - The parent section id
  @param {number} index - Zero-based block index
  @param {string} fallback_label - Label to show when image is missing
{%- enddoc -%}

<div
  class="tabbed-media__panel"
  role="tabpanel"
  ref="panels[]"
  id="TabbedMediaPanel-{{ section_id }}-{{ block.id }}"
  aria-labelledby="TabbedMediaTab-{{ section_id }}-{{ block.id }}"
  aria-hidden="{% if index == 0 %}false{% else %}true{% endif %}"
  {{ block.shopify_attributes }}
  {% unless index == 0 %}
    hidden
  {% endunless %}
>
  {% if block.settings.description != blank %}
    <div class="tabbed-media__panel-text rte">
      {{ block.settings.description }}
    </div>
  {% endif %}

  <div class="tabbed-media__image-wrapper">
    {% if block.settings.image != blank %}
      {% render 'image',
        image: block.settings.image,
        class: 'tabbed-media__image',
        style: 'width: 100%; height: 100%; object-fit: cover;'
      %}
    {% else %}
      <div class="tabbed-media__image-placeholder">
        {{ fallback_label | escape }}
      </div>
    {% endif %}

    <div class="tabbed-media__hotspots" data-hotspots-root>
      {% for hotspot_index in (1..3) %}
        {% liquid
          assign enabled_key = 'hotspot_' | append: hotspot_index | append: '_enabled'
          assign x_key = 'hotspot_' | append: hotspot_index | append: '_x'
          assign y_key = 'hotspot_' | append: hotspot_index | append: '_y'
          assign annotation_position_key = 'hotspot_' | append: hotspot_index | append: '_annotation_position'
          assign annotation_text_key = 'hotspot_' | append: hotspot_index | append: '_annotation_text'
          assign accessibility_label_key = 'hotspot_' | append: hotspot_index | append: '_accessibility_label'
        %}

        {% if block.settings[enabled_key] %}
          {% render 'tabbed-media-hotspot',
            hotspot_index: hotspot_index,
            x_position: block.settings[x_key],
            y_position: block.settings[y_key],
            annotation_position: block.settings[annotation_position_key],
            annotation_text: block.settings[annotation_text_key],
            accessibility_label: block.settings[accessibility_label_key]
          %}
        {% endif %}
      {% endfor %}
    </div>
  </div>
</div>
