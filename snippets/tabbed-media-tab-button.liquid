{%- doc -%}
  Renders a tab button for the tabbed media section.

  @param {object} block - The section block
  @param {string} section_id - The parent section id
  @param {number} index - Zero-based block index
{%- enddoc -%}

<button
  class="tabbed-media__tab"
  type="button"
  role="tab"
  ref="tabs[]"
  id="TabbedMediaTab-{{ section_id }}-{{ block.id }}"
  aria-controls="TabbedMediaPanel-{{ section_id }}-{{ block.id }}"
  aria-selected="{% if index == 0 %}true{% else %}false{% endif %}"
  tabindex="{% if index == 0 %}0{% else %}-1{% endif %}"
  {{ block.shopify_attributes }}
>
  <span class="tabbed-media__tab-label">{{ block.settings.label | escape }}</span>
</button>
