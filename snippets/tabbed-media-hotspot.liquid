{%- doc -%}
  Renders a hotspot marker with an annotation popup.

  @param {number} hotspot_index
  @param {number} x_position
  @param {number} y_position
  @param {string} annotation_position
  @param {string} annotation_text
  @param {string} accessibility_label
{%- enddoc -%}

<details
  class="tabbed-media__hotspot tabbed-media__hotspot--{{ annotation_position }}"
  style="--hotspot-x: {{ x_position }}%; --hotspot-y: {{ y_position }}%;"
  data-hotspot
  data-hotspot-index="{{ hotspot_index }}"
  data-x-field="hotspot_{{ hotspot_index }}_x"
  data-y-field="hotspot_{{ hotspot_index }}_y"
>
  <summary
    class="tabbed-media__hotspot-trigger"
    data-hotspot-drag-handle
    aria-label="{{ accessibility_label | escape }}"
  >
    <span class="tabbed-media__hotspot-circle">
      <svg
        class="tabbed-media__hotspot-plus"
        viewBox="0 0 18 18"
        fill="none"
        xmlns="http://www.w3.org/2000/svg"
        aria-hidden="true"
        focusable="false"
      >
        <line x1="9" y1="2" x2="9" y2="16"></line>
        <line x1="2" y1="9" x2="16" y2="9"></line>
      </svg>
    </span>
  </summary>

  <div class="tabbed-media__hotspot-note">
    {{ annotation_text | escape }}
  </div>

  <div class="tabbed-media__hotspot-helper" data-hotspot-helper>
    <strong>H{{ hotspot_index }}</strong>
    X:<span data-hotspot-x>{{ x_position }}</span>
    Y:<span data-hotspot-y>{{ y_position }}</span>
  </div>
</details>
