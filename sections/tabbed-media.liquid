        {
          "type": "range",
          "id": "hotspot_1_y",
          "label": "Hotspot 1 vertical position",
          "min": 0,
          "max": 100,
          "step": 1,
          "unit": "%",
          "default": 50
        },
        {
          "type": "select",
          "id": "hotspot_1_annotation_position",
          "label": "Hotspot 1 annotation position",
          "options": [
            {
              "value": "right",
              "label": "Right"
            },
            {
              "value": "left",
              "label": "Left"
            },
            {
              "value": "top",
